# Copy this file to backend/.env and fill in your values.

OPENAI_API_KEY=
# For Ollama local mode, set OPENAI_BASE_URL and you can keep OPENAI_API_KEY empty.
# Example: OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
SYSTEM_PROMPT=You are a helpful AI assistant for website visitors.

# Relative path is resolved from the backend directory.
DB_PATH=chat_history.db

# Basic per-IP request limit for /chat
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60

# Use "*" for development. In production, use explicit origins.
ALLOWED_ORIGINS=*

# Optional: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
